    +Farm(numberOfPlots: int)
    +addPlot(p: FarmPlot): void
    +tick(): void
    +activeEvents(): void
    +getActiveEvents(): ArrayList<FarmEvent>
    +getWorkersCapacity(): int
    +getWidth(): int
    +getLength(): int
    +getPrice(): int
}

CommercialBuilding <|-- FarmMarket
class FarmMarket {
    -inventory: Map<String, Integer>
    +sellCrop(crop: Crop, quantity: int): int
    +getPriceOf(crop: Crop): int
    +getVisitorsCapacity(): int
    +getWorkersCapacity(): int
    +getWidth(): int
    +getLength(): int
    +getPrice(): int
}

' Farm internal composition
Farm "1" *-- "*" FarmPlot
Farm "1" *-- "1" IrrigationSystem
Farm "1" o-- "*" FarmEvent
FarmPlot "0..1" o-- "1" Crop
FarmPlot ..> GrowthStage
FarmPlot ..> FarmEvent
IrrigationSystem o-- FarmPlot
Crop ..> GrowthStage
Crop ..> FarmEvent
FarmMarket ..> Crop

