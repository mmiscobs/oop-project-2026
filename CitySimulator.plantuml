    +isControlsVisible(): boolean
    +getControlsPanel(): JPanel
    +setTiles(grid: Image[][]): void
    +setTile(col: int, row: int, image: Image): void
    +setTileSize(tileWidth: int, tileHeight: int): void
    +setOrigin(x: int, y: int): void
    +setZoom(zoom: double): void
    +getZoom(): double
    +setTileSurfaceOffset(offsetPixels: int): void
    +setHoverHighlightVisible(visible: boolean): void
    +getColumns(): int
    +getRows(): int
