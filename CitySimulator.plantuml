    +attachComponent(comp: Component, col: int, row: int, anchor: TileAnchor): void
    +moveAttachment(comp: Component, col: int, row: int): void
    +detachComponent(comp: Component): void
    +addSprite(s: Sprite): void
    +removeSprite(s: Sprite): boolean
    +clearSprites(): void
